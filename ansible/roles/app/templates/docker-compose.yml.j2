# Шаблон Jinja2 — переменные подставляет Ansible
# {{ docker_hub_user }} и {{ app_version }} берутся из site.yml vars:
#   или из командной строки: -e "app_version=42"

services:
  backend:
    image: {{ docker_hub_user }}/devops-bootcamp-backend:{{ app_version }}
    restart: unless-stopped
    environment:
      - REDIS_URL=redis://redis:6379
      - APP_VERSION={{ app_version }}
    depends_on:
      - redis

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./index.html:/usr/share/nginx/html/index.html:ro
    depends_on:
      - backend

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    volumes:
      - redis_data:/data

volumes:
  redis_data:
